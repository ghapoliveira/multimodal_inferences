#  Participant data — Experiment 2 (raw EEG + E-Prime behavioral export)
#  Archived separately; empty skeleton kept via .gitkeep.
#  exp1_norming/data/ is anonymized norming data and is committed (not ignored).

exp2_eeg/data/**
!exp2_eeg/data/
!exp2_eeg/data/**/
!exp2_eeg/data/**/.gitkeep

# Per-participant papermill reports (regenerated by run_pipeline.py)
exp2_eeg/data/eeg/participant_*/reports/
exp2_eeg/data/eeg/participant_*/**/baseline_reports/
exp2_eeg/data/eeg/participant_*/**/alt_reports/


#  Individual-level outputs — NOT publishable under the EEG consent.
#  (Group derivatives — grand_averages, diff_waves, cluster_* — are kept.)
*_subjects-ave.fif
**/accuracy_by_subject.csv
**/summary_by_subject.csv
trial_counts_diagnostic.csv
**/eeg_continuous_for_julia.csv

#  Dissertation — local build tool (reads data others don't have).
#  Ignore the whole folder; un-ignore the final PDF if you want it in the repo.

/dissertation/
# !dissertation/_book/thesis.pdf
dissertation_eeg.py
r_dissertation_eeg.r
dissertation_pcibex.r


